<?xml version="1.0" encoding="utf-8"?>
<mujoco model="qube_servo3">
  <compiler angle="radian" inertiafromgeom="true"/>
  <option timestep="0.001" gravity="0 0 -9.82"/>

  <asset>
    <material name="cube_mat" rgba="0.2 0.2 0.2 1"/>
    <material name="arm_mat" rgba="0.5 0.5 0.5 1"/>
    <material name="pendulum_mat" rgba="1.0 0.2 0.2 1"/>
    <material name="joint_mat" rgba="0.3 0.3 0.3 1"/>
    <material name="led" rgba="1.0 0.0 0.0 0.5"/>
    <material name="floor" rgba="1 1 1 1"/>
  </asset>

  <worldbody>
    <!-- Floor -->
    <geom type="plane" size="1 1 0.05" material="floor" pos="0 0 -0.0001"/>

    <!-- Base (fixed to world) -->
    <body name="cube" pos="0 0 0.0501">
      <geom type="box" size="0.0501 0.0501 0.0501" mass="5.0" material="cube_mat"/>
      <geom type="box" size="0.05011" fromto="0 0 0.045 0 0 0.04" material="led"/>
    </body>

    <!-- Motor axis -->
    <body name="motor_axis" pos="0 0 0.123">
      <geom type="cylinder" size="0.011" fromto="0 0 -0.011 0 0 -0.0228" mass="0.0106" material="joint_mat"/>
      
      <!-- Encode attatched to motor -->
      <body name="arm" pos="0 0 0">
        <geom type="cylinder" size="0.014" fromto="0.01925 0 0 -0.033 0 0" mass="0.0106" material="pendulum_mat"/>
        <joint name="theta" type="hinge" pos="0 0 0" axis="0 0 1" limited="true" range="-1.5708 1.5708" damping="0.0"/>
        
        <!-- Pendulum attached to encoder -->
        <body name="pendulum" pos="0.085 0 0">
          <geom type="capsule" size="0.00325" fromto="-0.118 0 0 0.0025 0 0" mass="0.095" material="arm_mat"/>
          <geom type="cylinder" size="0.00475" fromto="0 0 0.0075 0 0 -0.1215" mass="0.024" material="pendulum_mat"/>
          <joint name="alpha" type="hinge" pos="0 0 0" axis="1 0 0" damping="0.0"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="arm_motor" joint="theta" gear="6.0" ctrlrange="-0.1 0.1"/>
  </actuator>
</mujoco>
